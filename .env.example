# Copy this file to `.env` and fill in values for this specific laptop.
# Never commit the real .env — it is gitignored.

# --- PlanHub account (one per laptop, scoped to one US state) ---
PLANHUB_EMAIL=youraccount@example.com
PLANHUB_PASSWORD=yourpassword

# --- Laptop identity (used in logs and telemetry) ---
LAPTOP_ID=laptop-01
STATE=CA

# --- Date range strategy ---
# Scraper processes ONE day at a time, starting this many days from today.
# Default 4 means: if deployed on April 19, it starts scraping projects due April 23,
# then April 24, April 25, etc. Gives the client enough lead time to actually bid.
START_DATE_OFFSET=4

# --- Telemetry backend (central dashboard) ---
# Leave TELEMETRY_URL blank to disable telemetry entirely (scraper still runs).
TELEMETRY_URL=https://planhub-telemetry.itscyper987.workers.dev
INGEST_TOKEN=paste-the-ingest-token-here
